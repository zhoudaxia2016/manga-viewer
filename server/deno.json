{
  "imports": {
    "jszip": "npm:jszip@3.10.1",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@3.700.0",
    "dotenv/load.ts": "jsr:@std/dotenv/load"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env --unstable-kv --allow-write --allow-sys main.ts",
    "debug": "deno run --inspect-brk --allow-net --allow-read --allow-env --unstable-kv --allow-write --allow-sys main.ts",
